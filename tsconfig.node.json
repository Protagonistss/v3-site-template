{
  "extends": "@ithinku/tsconfig/bundler",
  "compilerOptions": {
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "build/**/*.ts",
    "mock/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules"]
}
