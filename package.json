{
  "name": "vue3-admin-starter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.13.2",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "description": "Production-ready Vue 3 admin scaffold with Vite, TypeScript, Pinia and RBAC.",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src build mock tests vite.config.ts vitest.config.ts playwright.config.ts --ext .ts,.vue",
    "lint:fix": "eslint src build mock tests vite.config.ts vitest.config.ts playwright.config.ts --ext .ts,.vue --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "naive-ui": "^2.42.0",
    "nprogress": "^0.2.0",
    "pinia": "^2.2.2",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@ithinku/eslint-config-vue": "0.0.8",
    "@ithinku/tsconfig": "0.0.7",
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.7.7",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "eslint": "^9.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.93.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.2",
    "vitest": "^4.0.3",
    "vue-tsc": "^3.1.0"
  }
}
